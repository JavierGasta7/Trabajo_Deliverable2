<?xml version="1.0" encoding="ISO-8859-1"?>
<web-app>

    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>
	
	<servlet>
		<servlet-name>RateClassServlet</servlet-name>
		<servlet-class>RateClassServlet</servlet-class>
	</servlet>
	
	<servlet>
		<servlet-name>AdminDashboardServlet</servlet-name>
		<servlet-class>AdminDashboardServlet</servlet-class>
	</servlet>
	
	<servlet>
		<servlet-name>ClassCatalogueServlet</servlet-name>
		<servlet-class>ClassCatalogueServlet</servlet-class>
	</servlet>
	
	<servlet>
		<servlet-name>OccupancyMonitorServlet</servlet-name>
		<servlet-class>OccupancyMonitorServlet</servlet-class>
	</servlet>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>LoginServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>LogoutServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>BrowseClassesServlet</servlet-name>
        <servlet-class>BrowseClassesServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>BookClassServlet</servlet-name>
        <servlet-class>BookClassServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>CancelBookingServlet</servlet-name>
        <servlet-class>CancelBookingServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>BookingHistoryServlet</servlet-name>
        <servlet-class>BookingHistoryServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/LogoutServlet</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>BrowseClassesServlet</servlet-name>
        <url-pattern>/BrowseClassesServlet</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>BookClassServlet</servlet-name>
        <url-pattern>/BookClassServlet</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>CancelBookingServlet</servlet-name>
        <url-pattern>/CancelBookingServlet</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>BookingHistoryServlet</servlet-name>
        <url-pattern>/BookingHistoryServlet</url-pattern>
    </servlet-mapping>
	
	<servlet-mapping>
		<servlet-name>OccupancyMonitorServlet</servlet-name>
		<url-pattern>/OccupancyMonitorServlet</url-pattern>
	</servlet-mapping>
	
	<servlet-mapping>
		<servlet-name>RateClassServlet</servlet-name>
		<url-pattern>/RateClassServlet</url-pattern>
	</servlet-mapping>
	
	<servlet-mapping>
		<servlet-name>ClassCatalogueServlet</servlet-name>
		<url-pattern>/ClassCatalogueServlet</url-pattern>
	</servlet-mapping>
	
	<servlet-mapping>
		<servlet-name>AdminDashboardServlet</servlet-name>
		<url-pattern>/AdminDashboardServlet</url-pattern>
	</servlet-mapping>

</web-app>
